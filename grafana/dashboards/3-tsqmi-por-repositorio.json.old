          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  'CLI' as metric,\n  t.value as value,\n  t.value - LAG(t.value) OVER (ORDER BY t.created_at) as delta\nFROM tsqmi_tsqmi t\nJOIN organizations_repository r ON r.id = t.repository_id\nWHERE r.key LIKE '%measuresoftgram-cli'\n  AND t.created_at >= $__timeFrom()::timestamp\n  AND t.created_at <= $__timeTo()::timestamp\nORDER BY t.created_at DESC\nLIMIT 1",
