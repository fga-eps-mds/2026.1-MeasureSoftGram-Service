    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "measuresoftgram-db"
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 5,
      "options": {
        "code": {
          "language": "javascript",
          "showLineNumbers": true,
          "showMiniMap": false
        },
        "content": "// Gráfico 3 — TSQMI por Repositório\n// Ajustado para parecer com a imagem: linhas muito planas + pulsos pontuais\n\nconst REPO_META = {\n  cli:     { label: 'CLI',     color: '#1D9E75' },\n  core:    { label: 'Core',    color: '#378ADD' },\n  service: { label: 'Service', color: '#D85A30' },\n  front:   { label: 'Front',   color: '#D4537E' },\n  action:  { label: 'Action',  color: '#BA7517' },\n  ai:      { label: 'AI',      color: '#7F77DD' },\n  parser:  { label: 'Parser',  color: '#888780' }\n};\n\n// Função de pulso ECG com linhas MUITO planas (85% plano, 15% pulso)\nfunction msgPulse(scores, idxList) {\n  const SPS = 60;\n  const STABILITY_THRESHOLD = 0.02;\n  const pts = [];\n\n  for (let ii = 0; ii < idxList.length - 1; ii++) {\n    const a = scores[idxList[ii]];\n    const b = scores[idxList[ii + 1]];\n    const delta = b - a;\n    const absDelta = Math.abs(delta);\n\n    if (absDelta < STABILITY_THRESHOLD) {\n      // Linha perfeitamente plana\n      for (let s = 0; s < SPS; s++) {\n        const t = s / SPS;\n        const v = a + (b - a) * t;\n        pts.push(Math.max(0.01, Math.min(0.99, v)));\n      }\n    } else {\n      // Pulso ECG MUITO compacto (similar à imagem)\n      const pk = delta * 2.2;\n\n      for (let s = 0; s < SPS; s++) {\n        const t = s / SPS;\n        let v;\n\n        if (t < 0.45) {\n          // Linha de base inicial - 45%\n          v = a;\n        } else if (t < 0.50) {\n          // Subida do pico - 5% (muito rápida!)\n          const p = (t - 0.45) / 0.05;\n          v = a + pk * Math.sin(p * Math.PI * 0.5);\n        } else if (t < 0.55) {\n          // Descida do pico - 5%\n          const p = (t - 0.50) / 0.05;\n          v = a + pk * (1 - p);\n        } else if (t < 0.60) {\n          // Onda de retorno - 5%\n          const p = (t - 0.55) / 0.05;\n          v = b - delta * 0.15 * Math.sin(p * Math.PI);\n        } else {\n          // Nova linha de base - 40%\n          v = b;\n        }\n\n        pts.push(Math.max(0.01, Math.min(0.99, v)));\n      }\n    }\n  }\n\n  pts.push(Math.max(0.01, Math.min(0.99, scores[idxList[idxList.length - 1]])));\n  return pts;\n}\n\n// Processar dados das queries\nconst repoData = {};\ndata.series.forEach(series => {\n  const refId = series.refId.toLowerCase();\n  if (REPO_META[refId]) {\n    const timeField = series.fields.find(f => f.name === 'time');\n    const valueField = series.fields.find(f => f.name === series.refId);\n\n    if (timeField && valueField) {\n      repoData[refId] = {\n        label: REPO_META[refId].label,\n        color: REPO_META[refId].color,\n        datetimes: timeField.values,\n        tsqmi: valueField.values\n      };\n    }\n  }\n});\n\nconst repos = Object.keys(repoData);\nif (repos.length === 0) {\n  return { title: { text: 'Nenhum dado disponível', left: 'center', top: 'center' } };\n}\n\nconst firstRepo = repos[0];\nconst N = repoData[firstRepo].tsqmi.length;\nconst idxList = Array.from({ length: N }, (_, i) => i);\nconst SPS = 60;\n\nconst releases = [\n  { label: 'R1', dateIndex: 0 },\n  { label: 'R2', dateIndex: Math.floor(N / 2) },\n  { label: 'RN', dateIndex: N - 1 }\n];\n\nconst xLabels = [];\nidxList.forEach((idx, ii) => {\n  if (ii < idxList.length - 1) {\n    for (let s = 0; s < SPS; s++) xLabels.push(repoData[firstRepo].datetimes[idx]);\n  } else {\n    xLabels.push(repoData[firstRepo].datetimes[idx]);\n  }\n});\n\nconst series = repos.map(repoKey => {\n  const repo = repoData[repoKey];\n  return {\n    name: repo.label,\n    type: 'line',\n    smooth: false,\n    symbol: 'none',\n    lineStyle: {\n      color: repo.color,\n      width: 1.8,\n      type: 'solid'\n    },\n    data: msgPulse(repo.tsqmi, idxList),\n    markLine: {\n      silent: true,\n      symbol: 'none',\n      data: releases.map(rel => ({\n        xAxis: rel.dateIndex * SPS,\n        label: {\n          formatter: rel.label,\n          position: 'insideStartTop',\n          fontSize: 9,\n          fontWeight: 'bold',\n          color: '#BA7517'\n        },\n        lineStyle: {\n          color: '#BA7517',\n          type: 'dashed',\n          width: 1\n        }\n      }))\n    },\n    markPoint: {\n      symbol: 'circle',\n      symbolSize: 7,\n      data: releases.map(rel => ({\n        coord: [rel.dateIndex * SPS, repo.tsqmi[rel.dateIndex]],\n        itemStyle: { color: repo.color }\n      }))\n    }\n  };\n});\n\nconst isDark = theme.isDark;\nconst textColor = isDark ? 'rgba(255,255,255,0.7)' : 'rgba(0,0,0,0.6)';\nconst gridColor = isDark ? 'rgba(255,255,255,0.07)' : 'rgba(0,0,0,0.07)';\n\nreturn {\n  backgroundColor: 'transparent',\n  legend: {\n    data: repos.map(k => repoData[k].label),\n    textStyle: { color: textColor, fontSize: 11 },\n    bottom: 0\n  },\n  tooltip: {\n    trigger: 'axis',\n    formatter: params => {\n      const measureIdx = Math.min(Math.floor(params[0].dataIndex / SPS), N - 1);\n      const dt = new Date(repoData[firstRepo].datetimes[measureIdx]).toLocaleString('pt-BR');\n      const rel = releases.find(r => r.dateIndex === measureIdx);\n      let html = '<b>' + dt + '</b>';\n      if (rel) html += '<br/><span style=\"color:#BA7517\">● ' + rel.label + '</span>';\n\n      params.forEach(p => {\n        const repoKey = repos[p.seriesIndex];\n        const repo = repoData[repoKey];\n        const v = repo.tsqmi[measureIdx];\n        const prev = measureIdx > 0 ? repo.tsqmi[measureIdx - 1] : null;\n        const delta = prev !== null ? v - prev : null;\n        const col = delta !== null ? (delta >= 0 ? '#1D9E75' : '#E24B4A') : textColor;\n\n        html += '<br/><span style=\"color:' + repo.color + '\">■</span> ' + repo.label + ': <b>' + v.toFixed(2) + '</b>';\n        if (delta !== null) html += ' <span style=\"color:' + col + '\">' + (delta >= 0 ? '+' : '') + delta.toFixed(2) + '</span>';\n      });\n\n      return html;\n    }\n  },\n  grid: { top: 20, bottom: 50, left: 50, right: 20 },\n  xAxis: {\n    type: 'category',\n    data: xLabels,\n    axisLabel: {\n      color: textColor,\n      fontSize: 10,\n      interval: SPS * Math.floor(N / 5) - 1,\n      formatter: v => {\n        if (!v) return '';\n        const d = new Date(v);\n        return String(d.getDate()).padStart(2, '0') + '/' + String(d.getMonth() + 1).padStart(2, '0');\n      }\n    },\n    splitLine: { show: false },\n    axisLine: { lineStyle: { color: gridColor } }\n  },\n  yAxis: {\n    type: 'value',\n    min: 0,\n    max: 1,\n    interval: 0.25,\n    axisLabel: {\n      color: textColor,\n      fontSize: 9,\n      formatter: v => v.toFixed(2)\n    },\n    splitLine: { lineStyle: { color: gridColor } }\n  },\n  series\n};\n",
        "mode": "code"
      },
      "pluginVersion": "10.0.0",
